# Kopiraj u `.env.local` i popuni vrijednosti. `.env.local` se ne šalje na GitHub.
# Admin prijava: bez barem jednog para email + bcrypt hash, /api/auth/login vraća 503.

# Javni URL stranice (Open Graph, kanonski linkovi). Lokalno: http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://tvoja-domena.hr

# --- Admin (barem jedan par obavezan za prijavu) ---
# ADMIN_EMAIL=admin@example.com
# Lozinka u bazi je bcrypt hash (ne običan tekst). Generacija u koriju projekta:
#   node -e "console.log(require('bcryptjs').hashSync('tvoja-lozinka', 12))"
# U .env datoteci znak $ u hashu treba escapeati kao \$ ili staviti hash u jednostruke navodnike.
# ADMIN_PASSWORD_HASH=

# ADMIN2_EMAIL=
# ADMIN2_PASSWORD_HASH=

# Opcionalno: puno ime ako želiš override (min. dvije riječi, inače se koristi default iz site konfiguracije)
# ADMIN_DISPLAY_NAME=
# ADMIN2_DISPLAY_NAME=

# Produkcija: postavi nasumičan dugi string (ne dijeliti). Ako nije setano, koristi se slabiji fallback.
# SESSION_COOKIE_SECURE=true
# ADMIN_SESSION_SECRET=

# --- Kontakt forma (Resend) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev
# CONTACT_EMAIL_TO=tvoj@email.com

# --- Galerija (opcionalno; default u kodu) ---
# GALLERY_ADMIN_EMAIL=
